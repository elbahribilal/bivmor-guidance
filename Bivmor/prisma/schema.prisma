// Moroccan Educational Platform - Database Schema
// منصة المباريات والفرص التعليمية في المغرب

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

// ============================================
// USER & AUTHENTICATION (Admin Users Only)
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  role      Role     @default(ADMIN)
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  MODERATOR
}

// ============================================
// PLATFORM USERS (Regular Users)
// ============================================

model PlatformUser {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?   // nullable for OAuth
  avatar        String?
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  lastLoginAt   DateTime?

  // User preferences
  preferredCityId  String?
  preferredCity     City? @relation(fields: [preferredCityId], references: [id])
  notificationPrefs String? // JSON string for notification preferences

  // Relations
  favorites        UserFavorite[]
  userReminders    UserReminder[]
  userApplications UserApplication[]
  userNotifications UserNotification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// GEOGRAPHIC DATA
// ============================================

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  nameAr    String?
  nameFr    String?
  slug      String   @unique
  cities    City[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id              String          @id @default(cuid())
  name            String
  nameAr          String?
  nameFr          String?
  slug            String
  regionId        String
  region          Region          @relation(fields: [regionId], references: [id])
  schools         School[]
  competitions    Competition[]
  platformUsers   PlatformUser[]
  order           Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([name, regionId])
}

// ============================================
// EDUCATION STRUCTURE
// ============================================

model Level {
  id           String       @id @default(cuid())
  name         String       @unique
  nameAr       String?
  nameFr       String?
  slug         String       @unique
  order        Int          @default(0)
  competitions Competition[]
  schools      School[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Category {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  nameAr       String?
  nameFr       String?
  icon         String?
  color        String?
  description  String?
  order        Int          @default(0)
  parentId     String?
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  competitions Competition[]
  schools      School[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// ============================================
// SCHOOLS / INSTITUTIONS
// ============================================

model School {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  shortDescription String?
  fullDescription String?
  logo            String?
  coverImage      String?
  website         String?
  email           String?
  phone           String?
  address         String?
  cityId          String
  city            City       @relation(fields: [cityId], references: [id])
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  levelId         String?
  level           Level?     @relation(fields: [levelId], references: [id])
  isFeatured      Boolean    @default(false)
  isActive        Boolean    @default(true)
  type            SchoolType @default(PUBLIC)
  competitions    Competition[]
  media           Media[]
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

enum SchoolType {
  PUBLIC
  PRIVATE
  SEMI_PRIVATE
}

// ============================================
// COMPETITIONS / CONCOURS
// ============================================

model Competition {
  id               String             @id @default(cuid())
  title            String
  slug             String             @unique
  shortDescription String?
  fullDescription  String?
  officialLink     String?
  registrationOpen Boolean            @default(true)
  deadline         DateTime?
  startDate        DateTime?
  endDate          DateTime?
  requirements     String?
  documents        String?
  stages           String?
  featuredImage    String?
  cityId           String?
  city             City?              @relation(fields: [cityId], references: [id])
  schoolId         String?
  school           School?            @relation(fields: [schoolId], references: [id])
  categoryId       String?
  category         Category?          @relation(fields: [categoryId], references: [id])
  levelId          String?
  level            Level?             @relation(fields: [levelId], references: [id])
  isFeatured       Boolean            @default(false)
  isPinned         Boolean            @default(false)
  isArchived       Boolean            @default(false)
  status           CompetitionStatus  @default(OPEN)
  type             CompetitionType    @default(ACADEMIC)
  media            Media[]
  tags             CompetitionTag[]
  userReminders    UserReminder[]
  userApplications UserApplication[]
  seoTitle         String?
  seoDescription   String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

enum CompetitionStatus {
  OPEN
  CLOSED
  EXPIRED
  UPCOMING
}

enum CompetitionType {
  RECRUITMENT
  ACADEMIC
  SCHOLARSHIP
  CONTINUING_EDUCATION
  ADMISSION
}

// ============================================
// TAGS
// ============================================

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  slug         String           @unique
  competitions CompetitionTag[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model CompetitionTag {
  competitionId String
  tagId         String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([competitionId, tagId])
}

// ============================================
// MEDIA
// ============================================

model Media {
  id            String    @id @default(cuid())
  url           String
  alt           String?
  type          MediaType @default(IMAGE)
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  competitionId String?
  competition   Competition? @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  LOGO
}

// ============================================
// NOTIFICATIONS (Admin/System)
// ============================================

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  userId    String?
  createdAt DateTime         @default(now())
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

// ============================================
// NEWS / ANNOUNCEMENTS
// ============================================

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  category    String   @default("إعلان")
  isPublished Boolean  @default(true)
  isPinned    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================
// SITE SETTINGS
// ============================================

model SiteSetting {
  id        String      @id @default(cuid())
  key       String      @unique
  value     String
  type      SettingType @default(TEXT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum SettingType {
  TEXT
  JSON
  NUMBER
  BOOLEAN
}

// ============================================
// ACTIVITY LOG
// ============================================

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())
}

// ============================================
// USER DATA SYNC TABLES (PlatformUser)
// ============================================

model UserFavorite {
  id       String @id @default(cuid())
  userId   String
  user     PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId   String
  itemType String // 'competition' or 'school'

  createdAt DateTime @default(now())

  @@unique([userId, itemId, itemType])
}

model UserReminder {
  id             String   @id @default(cuid())
  userId         String
  user           PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId  String
  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  reminderDate   DateTime
  notes          String?
  isNotified     Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, competitionId, reminderDate])
}

model UserApplication {
  id             String   @id @default(cuid())
  userId         String
  user           PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  competitionId  String
  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  status         String   @default("لم أبدأ") // لم أبدأ/أحضّر/قدّمت/قيد المراجعة/مقبول/مرفوض
  notes          String?
  appliedDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, competitionId])
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      PlatformUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO") // INFO/WARNING/SUCCESS/ERROR
  isRead    Boolean  @default(false)
  link      String?

  createdAt DateTime @default(now())
}

// ============================================
// ADMIN AUDIT LOG
// ============================================

model AdminAuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  userRole  String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}

