# ==========================================
# 1. إعدادات قاعدة البيانات (PostgreSQL)
# ==========================================
# ستحتاج إلى إنشاء قاعدة بيانات (مثلاً على Supabase أو Render أو سيرفرك الشخصي) ووضع الرابط هنا:
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres"

# ==========================================
# 2. المفاتيح السرية والأمان (Security Secrets)
# ==========================================
# لقد قمت بتوليد مفاتيح تشفير قوية لك (لا تشاركها أبداً)
NEXTAUTH_SECRET="T1x8Kz9pL4vH2qB5nW8eR7tY1uI4oP0sA3dF6gJ9hK2lM5"
USER_JWT_SECRET="x8Kz9pL4vH2qB5nW8eR7tY1uI4oP0sA3dF6gJ9hK2lM5T1"
ADMIN_INIT_SECRET="bivmor-init-2026-secure" # ستحتاجه لإنشاء أول حساب أدمن

# ==========================================
# 3. إعدادات النطاق (URLs)
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000" # غيره لاحقاً إلى رابط موقعك
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# 4. إعدادات الجلسات (Sessions)
# ==========================================
ADMIN_SESSION_MAX_AGE="43200" # 12 ساعة فقط لزيادة الأمان للأدمن
USER_SESSION_MAX_AGE="604800" # 7 أيام للمستخدم العادي
BCRYPT_ROUNDS="12"

# ==========================================
# 5. إعدادات فصل الأدمين والباكاند (المرحلة القادمة)
# ==========================================
NEXT_PUBLIC_ADMIN_ROUTE="/admin-panel"
ADMIN_IS_SEPARATE="false" # سنجعلها true عندما نفصل الأدمين تماماً
ADMIN_API_BASE_URL=""
